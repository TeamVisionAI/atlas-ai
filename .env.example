# Atlas AI — environment template (copy to .env and fill in real values)
# Never commit .env or real secrets.

# Server
PORT=3000
FRONTEND_URL=http://localhost:3000
# Note: Vite dev server runs on http://localhost:5173 — use that for Meta allowed domains during local UI testing.

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=

# WhatsApp Cloud API (existing test-number integration)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
VERIFY_TOKEN=

# Meta Embedded Signup (Sprint 6 — server-side only except public App ID / Config ID in frontend)
META_APP_ID=
META_APP_SECRET=
META_EMBEDDED_SIGNUP_CONFIG_ID=
META_GRAPH_API_VERSION=v21.0
META_TOKEN_ENCRYPTION_KEY=

# Public website contact form (Resend — server-side only)
RESEND_API_KEY=
CONTACT_FORM_FROM_EMAIL=Team Vision Financial <notifications@teamvisionfinancial.com>
CONTACT_FORM_TO_EMAIL=contact@teamvisionfinancial.com

# Set VITE_META_APP_ID to the same value as META_APP_ID for the browser SDK.
VITE_META_APP_ID=
VITE_META_EMBEDDED_SIGNUP_CONFIG_ID=
VITE_META_GRAPH_API_VERSION=v21.0
