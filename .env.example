# Atlas AI — environment template (copy to .env and fill in real values)
# Never commit .env or real secrets.

# Server
PORT=3000
FRONTEND_URL=http://localhost:3000
# Note: Vite dev server runs on http://localhost:5173 — use that for Meta allowed domains during local UI testing.

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Dev tooling only (Sprint 15.5+) — Supabase → Project Settings → Database
# Use DATABASE_URL or SUPABASE_DB_PASSWORD for migration apply / RC1 certification
DATABASE_URL=
SUPABASE_DB_PASSWORD=

# WhatsApp Cloud API (existing test-number integration)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
VERIFY_TOKEN=

# Facebook Messenger (Sprint 12.1 — Communication Gateway)
MESSENGER_PAGE_ACCESS_TOKEN=
MESSENGER_PAGE_ID=

# Atlas AI (Sprint 12.2 — Communication Gateway AI adapter)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Meta Embedded Signup (Sprint 6 — server-side only except public App ID / Config ID in frontend)
META_APP_ID=
META_APP_SECRET=
META_EMBEDDED_SIGNUP_CONFIG_ID=
META_GRAPH_API_VERSION=v25.0
META_TOKEN_ENCRYPTION_KEY=

# Public website contact form (Resend — server-side only)
RESEND_API_KEY=
CONTACT_FORM_FROM_EMAIL=Team Vision Financial <notifications@teamvisionfinancial.com>
CONTACT_FORM_TO_EMAIL=contact@teamvisionfinancial.com

# Set VITE_META_APP_ID to the same value as META_APP_ID for the browser SDK.
VITE_META_APP_ID=
VITE_META_EMBEDDED_SIGNUP_CONFIG_ID=
VITE_META_GRAPH_API_VERSION=v25.0

# Google Calendar (interview booking — required for full MVP pipeline)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_REFRESH_TOKEN=

# Frontend API base URL
# Local dev: leave empty — Vite proxies /api to http://localhost:3000 (see frontend/vite.config.js)
# Production (Vercel): set to your Railway API URL, e.g. https://your-service.up.railway.app
VITE_API_BASE_URL=
VITE_ATLAS_BOOTSTRAP_TOKEN=
