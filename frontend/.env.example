# Frontend environment variables

# Copy to frontend/.env and fill in real values.
# Never commit .env or real secrets.

# ---------------------------------------------------------------------------
# API routing
# ---------------------------------------------------------------------------

# Production only — Railway (or other) API base URL, no trailing slash.
# Example: https://your-service.up.railway.app
#
# Local development: leave empty. Vite proxies /api → http://localhost:3000
# (see vite.config.js). Do NOT point local dev at production.
VITE_API_BASE_URL=

# ---------------------------------------------------------------------------
# Atlas authentication (internal app)
# ---------------------------------------------------------------------------

# Bootstrap token for POST /api/auth/session.
# Must match ATLAS_BOOTSTRAP_TOKEN in the backend root .env.
# Used by /app/* routes (Quick Capture, Knowledge Hub, etc.).
VITE_ATLAS_BOOTSTRAP_TOKEN=

# ---------------------------------------------------------------------------
# Meta Embedded Signup (public IDs — safe in browser bundle)
# ---------------------------------------------------------------------------

# Same value as backend META_APP_ID
VITE_META_APP_ID=

# Same value as backend META_EMBEDDED_SIGNUP_CONFIG_ID
VITE_META_EMBEDDED_SIGNUP_CONFIG_ID=

# Graph API version (default v25.0)
VITE_META_GRAPH_API_VERSION=v25.0
