const {
  findProspect,
  createProspect,
  updateProspect
} = require("./supabaseService");

const { createInterview } = require("./calendarService");
const { detectIntent } = require("./intentEngine");
const { routeConversation } = require("./conversationRouter");
const { getResponse } = require("./responseEngine");
const { buildMemory } = require("./memoryEngine");

const {
  validateAnswer,
  getValidationReply
} = require("./validationEngine");

const { logConversation } = require("./logService");

/**
 * Receives one incoming WhatsApp message and decides how Atlas responds.
 */
async function handleIncomingMessage(phone, name, message) {
  const cleanMessage = String(message || "").trim();
  const intent = detectIntent(cleanMessage);

  console.log("\n==============================");
  console.log("ATLAS INTENT ENGINE");
  console.log("Message:", cleanMessage);
  console.log("Intent :", intent);
  console.log("==============================\n");

  let prospect = await findProspect(phone);

  console.log("========== FIND PROSPECT ==========");
  console.log(prospect);
  console.log("===================================");

  // Create a new prospect on the first message.
  if (!prospect) {

    await createProspect(phone, name, cleanMessage);

    await logConversation({
        phone,
        name,
        direction: "incoming",
        message: cleanMessage,
        intent,
        pipeline: "NEW",
        currentStep: "GREETING",
        language: "en",
        city: null,
        state: null
    });

    return `👋 Welcome to Team Vision!

I'm Atlas, your virtual recruiting assistant.

What city and state do you currently live in?`;

}

  const memory = buildMemory(prospect);

  await logConversation({
    phone,
    name,
    direction: "incoming",
    message,
    intent,
    pipeline: prospect.pipeline,
    currentStep: prospect.current_step,
    language: memory.language,
    city: prospect.city,
    state: prospect.state
});
  const language = memory.language === "es" ? "es" : "en";

  console.log("\n========== ATLAS MEMORY ==========");
  console.log(memory);
  console.log("==================================\n");

  // Handle questions or objections before validating the workflow answer.
  const route = routeConversation({
    prospect,
    message: cleanMessage,
    intent
  });

  if (route.interrupt) {
    const interruptionReply = getResponse(intent, language);

    if (interruptionReply) {
      return `${interruptionReply}

${getCurrentQuestion(prospect.current_step, language)}`;
    }
  }

  // Validate the answer expected at the current workflow step.
  const validation = validateAnswer(
    prospect.current_step,
    cleanMessage
  );

  console.log("========== VALIDATION ==========");
  console.log(validation);
  console.log("================================");

  if (!validation.valid) {
    return getValidationReply(
      validation.reason,
      language
    );
  }

  // Continue the normal recruiting workflow.
  switch (prospect.current_step) {
    case "GREETING":
      return handleGreetingStep(prospect, cleanMessage, language);

    case "WORK_AUTHORIZATION":
      return handleWorkAuthorizationStep(
        prospect,
        cleanMessage,
        language
      );

    case "OCCUPATION":
      return handleOccupationStep(
        prospect,
        cleanMessage,
        language
      );

    case "INTERVIEW_TYPE":
      return handleInterviewTypeStep(
        prospect,
        cleanMessage,
        language
      );

    case "SCHEDULE":
      return handleScheduleStep(
        prospect,
        cleanMessage,
        language
      );

    case "CONFIRMED":
      return language === "es"
        ? "✅ Tu entrevista ya está confirmada. Un líder de Team Vision se comunicará contigo si es necesario realizar algún ajuste."
        : "✅ Your interview is already confirmed. A Team Vision leader will contact you if any adjustment is needed.";

    default:
      return language === "es"
        ? "Gracias. Atlas todavía está aprendiendo. 😊"
        : "Thanks! Atlas is still learning. 😊";
  }
}

/**
 * Saves city and state, then advances to work authorization.
 */
async function handleGreetingStep(prospect, message, language) {
  let city = message;
  let state = "";

  if (message.includes(",")) {
    const parts = message.split(",");
    city = parts[0].trim();
    state = parts.slice(1).join(",").trim();
  }

  await updateProspect(prospect.phone, {
    city,
    state,
    current_step: "WORK_AUTHORIZATION",
    last_message: message
  });

  return language === "es"
    ? "Perfecto. ✅\n\n¿Tienes autorización legal para trabajar en los Estados Unidos?"
    : "Perfect! ✅\n\nDo you have legal authorization to work in the United States?";
}

/**
 * Saves work-authorization status, then asks for occupation.
 */
async function handleWorkAuthorizationStep(
  prospect,
  message,
  language
) {
  const answer = message.toLowerCase();

  const yesAnswers = [
    "yes",
    "y",
    "yeah",
    "yep",
    "si",
    "sí",
    "green card",
    "citizen",
    "citizenship",
    "usc",
    "work permit",
    "permit",
    "tps",
    "authorized",
    "autorizado",
    "autorizada"
  ];

  const authorized = yesAnswers.some((value) =>
    answer.includes(value)
  );

  await updateProspect(prospect.phone, {
    work_authorized: authorized,
    current_step: "OCCUPATION",
    last_message: message
  });

  return language === "es"
    ? "Excelente. ¿En qué trabajas actualmente?"
    : "Great! What do you currently do for work?";
}

/**
 * Saves occupation, then asks for interview type.
 */
async function handleOccupationStep(
  prospect,
  message,
  language
) {
  await updateProspect(prospect.phone, {
    occupation: message,
    current_step: "INTERVIEW_TYPE",
    last_message: message
  });

  return language === "es"
    ? `¡Perfecto! 👍

¿Cómo prefieres realizar tu entrevista?

1️⃣ Presencial

2️⃣ Por Zoom`
    : `Awesome! 👍

Would you prefer your interview:

1️⃣ In person

2️⃣ On Zoom`;
}

/**
 * Saves interview type, then offers available times.
 */
async function handleInterviewTypeStep(
  prospect,
  message,
  language
) {
  const answer = message.toLowerCase();

  let interviewType = "Zoom";

  if (
    answer.includes("1") ||
    answer.includes("in person") ||
    answer.includes("in-person") ||
    answer.includes("person") ||
    answer.includes("office") ||
    answer.includes("presencial")
  ) {
    interviewType = "In Person";
  }

  await updateProspect(prospect.phone, {
    interview_type: interviewType,
    current_step: "SCHEDULE",
    last_message: message
  });

  return language === "es"
    ? `¡Perfecto! 🎉

¿Qué horario te funciona mejor?

1️⃣ 1:00 PM

2️⃣ 5:00 PM`
    : `Perfect! 🎉

Which interview time works best for you?

1️⃣ 1:00 PM

2️⃣ 5:00 PM`;
}

/**
 * Creates the Google Calendar interview and confirms it.
 */
async function handleScheduleStep(
  prospect,
  message,
  language
) {
  const answer = message.toLowerCase();

  let interviewTime = "5:00 PM";
  let hour = 17;

  if (
    answer === "1" ||
    answer.includes("1:00") ||
    answer.includes("1 pm")
  ) {
    interviewTime = "1:00 PM";
    hour = 13;
  }

  const startTime = new Date();
  startTime.setDate(startTime.getDate() + 1);
  startTime.setHours(hour, 0, 0, 0);

  const event = await createInterview({
    name: prospect.name,
    phone: prospect.phone,
    interviewType: prospect.interview_type,
    startTime: startTime.toISOString()
  });

  await updateProspect(prospect.phone, {
    interview_time: interviewTime,
    calendar_event_id: event.id,
    current_step: "CONFIRMED",
    last_message: message
  });

  return language === "es"
    ? `✅ ¡Excelente!

Tu entrevista ha sido programada para mañana a la ${interviewTime}.

Un líder de Team Vision se comunicará contigo si es necesario realizar algún ajuste.

¡Esperamos conocerte!`
    : `✅ Excellent!

Your interview has been scheduled for tomorrow at ${interviewTime}.

A Team Vision leader will contact you if any adjustment is needed.

We look forward to meeting you!`;
}

/**
 * Restates the current workflow question after answering an interruption.
 */
function getCurrentQuestion(step, language) {
  const questions = {
    GREETING: {
      en: "Now, what city and state do you currently live in?",
      es: "Ahora, ¿en qué ciudad y estado vives actualmente?"
    },

    WORK_AUTHORIZATION: {
      en: "Now, do you have legal authorization to work in the United States?",
      es: "Ahora, ¿tienes autorización legal para trabajar en los Estados Unidos?"
    },

    OCCUPATION: {
      en: "Now, what do you currently do for work?",
      es: "Ahora, ¿en qué trabajas actualmente?"
    },

    INTERVIEW_TYPE: {
      en: "Would you prefer your interview in person or on Zoom?",
      es: "¿Prefieres realizar tu entrevista presencialmente o por Zoom?"
    },

    SCHEDULE: {
      en: "Which time works best: 1:00 PM or 5:00 PM?",
      es: "¿Qué horario te funciona mejor: 1:00 PM o 5:00 PM?"
    }
  };

  return questions[step]?.[language] || "";
}

module.exports = {
  handleIncomingMessage
};